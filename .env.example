# Site URL — production canonical
NUXT_PUBLIC_SITE_URL=https://blog.roibase.com.tr

# noindex flag — staging/preview için açık tutulur, prod'da false yapılır
# robots.txt + meta tag ikisi birden bu flag'i okur
NUXT_PUBLIC_NOINDEX=true

# Hosting — Outplane node-server için boş bırakılabilir
# Cloudflare Pages için: NITRO_PRESET=cloudflare-pages
NITRO_PRESET=node-server
